---
import '../styles/global.css';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Tools & Resources | diShine Digital Agency</title>
  </head>
  <body class="bg-[#0f1115] text-gray-100 antialiased min-h-screen">
    <header class="bg-[#161b22] border-b border-gray-800 sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <a href="/" class="text-xl font-bold text-white tracking-tight">
            diShine<span class="text-blue-500">_</span>Toolkit
          </a>
        </div>
        <nav>
          <a href="https://github.com/diShine-digital-agency/Tools-and-Resources" target="_blank" class="text-sm font-medium text-gray-400 hover:text-white transition-colors">
            GitHub Repo
          </a>
        </nav>
      </div>
    </header>
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <slot />
    </main>
    <footer class="border-t border-gray-800 py-8 mt-12 text-center text-gray-500 text-sm">
      <p>&copy; {new Date().getFullYear()} diShine Digital Agency. Open Source under MIT License.</p>
    </footer>
  </body>
</html>
