---
import Layout from '../layouts/Layout.astro';
import ToolCard from '../components/ToolCard.astro';
import toolsData from '../data/tools.json';
import stacksData from '../data/stacks.json';

const categories = [...new Set(toolsData.map((t: any) => t.category))];
---

<Layout>
  <div class="mb-16 max-w-3xl">
    <h1 class="text-4xl sm:text-5xl font-extrabold text-white tracking-tight mb-6">
      The Curated Digital <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-emerald-400">Toolkit</span>.
    </h1>
    <p class="text-lg text-gray-400 leading-relaxed mb-8">
      A curated collection of {toolsData.length} digital tools, platforms, and resources for agencies, consultants, and digital teams. Every tool has been evaluated for practical value. 
    </p>

    <!-- Search input -->
    <div class="relative max-w-2xl">
      <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
        <svg class="h-5 w-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
      </div>
      <input type="text" id="searchInput" class="block w-full pl-11 pr-4 py-3.5 border border-gray-700/80 rounded-xl leading-config bg-[#161b22] text-gray-100 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent text-base shadow-sm transition-all" placeholder="Search by name, category, or alternative (e.g. 'Jira')..." />
    </div>
  </div>

  <div class="mb-20">
    <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
      <svg class="h-5 w-5 text-yellow-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
      Agency Playbooks
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {stacksData.map((stack: any) => (
        <div class="p-6 rounded-xl bg-[#161b22] border border-gray-800">
          <h3 class="text-lg font-bold text-white mb-2">{stack.name}</h3>
          <p class="text-sm text-gray-400 mb-5">{stack.description}</p>
          <div class="flex flex-wrap gap-2">
            {stack.tools.map((t: string) => (
              <span class="px-2 py-1 bg-gray-800 rounded font-medium text-xs text-gray-300">{t}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>

  <div id="toolsContainer">
    {categories.map((category: unknown) => (
      <div class="category-section mb-16" data-category={category}>
        <h2 class="text-xl font-bold text-gray-100 mb-6 flex items-center gap-3">
          {category}
          <span class="text-xs font-semibold text-gray-400 px-2.5 py-0.5 bg-gray-800 rounded-full">
            {toolsData.filter((t: any) => t.category === category).length}
          </span>
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5 tools-grid">
          {toolsData.filter((t: any) => t.category === category).map((tool: any) => (
            <div class="tool-card-wrapper h-full" data-name={tool.name?.toLowerCase() || ''} data-desc={tool.description?.toLowerCase() || ''} data-alt={tool.alternativeTo?.toLowerCase() || ''}>
              <ToolCard tool={tool} />
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>

  <!-- Search Script -->
  <script>
    const searchInput = document.getElementById('searchInput');
    const categorySections = document.querySelectorAll('.category-section');

    searchInput?.addEventListener('input', (e) => {
      const target = e.target as HTMLInputElement;
      if (!target) return;
      const term = target.value.toLowerCase();

      categorySections.forEach((section) => {
        let sectionHasVisible = false;
        const tools = section.querySelectorAll('.tool-card-wrapper');
        
        tools.forEach((tool) => {
          const t = tool as HTMLElement;
          const match = (t.dataset.name && t.dataset.name.includes(term)) || 
                        (t.dataset.desc && t.dataset.desc.includes(term)) || 
                        (t.dataset.alt && t.dataset.alt.includes(term));
          
          if (match) {
            t.style.display = 'block';
            sectionHasVisible = true;
          } else {
            t.style.display = 'none';
          }
        });

        const s = section as HTMLElement;
        if (sectionHasVisible || term === '') {
          s.style.display = 'block';
        } else {
          s.style.display = 'none';
        }
      });
    });
  </script>
</Layout>
