---
import Layout from '../layouts/Layout.astro';
import ToolCard from '../components/ToolCard.astro';
import toolsData from '../data/tools.json';
import stacksData from '../data/stacks.json';
import { normalizeTools } from '../lib/toolkit-core.js';

const normalizedTools = normalizeTools(toolsData);
const categories = [...new Set(normalizedTools.map((tool) => tool.category))];
const pricingCounts = normalizedTools.reduce((counts, tool) => {
  counts[tool.pricing] = (counts[tool.pricing] || 0) + 1;
  return counts;
}, { free: 0, freemium: 0, 'open-source': 0, paid: 0 });
---

<Layout>
  <style is:inline>
    details > summary { list-style: none; }
    details > summary::-webkit-details-marker { display: none; }
  </style>

  <div class="flex flex-col lg:flex-row gap-6">
    <div class="flex-1 min-w-0">
      <div class="mb-10 max-w-4xl">
        <span class="inline-flex items-center gap-2 rounded-full border border-blue-900/60 bg-blue-950/30 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-blue-300">
          diShine Digital Agency
        </span>
        <h1 class="mt-5 text-4xl sm:text-5xl font-extrabold text-white tracking-tight mb-6">
          Client-ready tool stacks, with smarter <span class="text-blue-500">alternative matching</span>.
        </h1>
        <p class="text-lg text-gray-400 leading-relaxed mb-8">
          Curated tools for delivery, growth, design, and operations. Build a stack, compare stronger free and paid alternatives, and export the full recommendation as branded PDF, TXT, or Markdown.
        </p>
        <div class="grid gap-4 sm:grid-cols-3">
          <div class="rounded-xl border border-gray-800 bg-[#161b22] p-4">
            <p class="text-xs uppercase tracking-[0.18em] text-gray-500 mb-2">Audit focus</p>
            <p class="text-sm text-gray-300">Alternatives now prioritize the same utility before broader same-category fallbacks.</p>
          </div>
          <div class="rounded-xl border border-gray-800 bg-[#161b22] p-4">
            <p class="text-xs uppercase tracking-[0.18em] text-gray-500 mb-2">Export</p>
            <p class="text-sm text-gray-300">Every export includes the chosen stack plus both free and paid recommendation sets.</p>
          </div>
          <div class="rounded-xl border border-gray-800 bg-[#161b22] p-4">
            <p class="text-xs uppercase tracking-[0.18em] text-gray-500 mb-2">Experience</p>
            <p class="text-sm text-gray-300">Cleaner pricing filters, clearer stack states, and a more branded client handoff flow.</p>
          </div>
        </div>
      </div>

      <div class="bg-[#161b22] border border-gray-800 rounded-xl p-6 mb-12 flex flex-col gap-4">
        <div class="flex flex-col lg:flex-row gap-4 items-center justify-between">
          <div class="relative w-full lg:w-1/2">
            <input type="text" id="searchInput" placeholder="Search by name, category, use case, tags, or description..." class="w-full pl-4 pr-10 py-3 rounded-lg bg-[#0f1115] text-gray-100 border border-gray-700/80 focus:ring-2 focus:ring-blue-500 transition-all font-medium" />
            <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
              <svg class="h-5 w-5 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
            </div>
          </div>
          <div class="w-full lg:w-auto rounded-lg border border-gray-800 bg-[#0f1115] px-4 py-3 text-sm text-gray-400">
            <p class="font-semibold text-gray-200">{normalizedTools.length} tools · {categories.length} categories</p>
            <p>Use search, tags, and pricing filters to narrow the list before stacking.</p>
          </div>
        </div>
        <div class="flex gap-3 overflow-x-auto pb-2">
          <button class="pricing-filter active text-[11px] font-bold px-4 py-2.5 rounded-lg border transition-colors whitespace-nowrap bg-blue-600 text-white border-blue-500" data-pricing="all">All ({normalizedTools.length})</button>
          <button class="pricing-filter text-[11px] font-bold px-4 py-2.5 rounded-lg border transition-colors whitespace-nowrap bg-[#0f1115] text-emerald-400 border-emerald-800/50 hover:bg-emerald-900/30" data-pricing="free">Free ({pricingCounts.free})</button>
          <button class="pricing-filter text-[11px] font-bold px-4 py-2.5 rounded-lg border transition-colors whitespace-nowrap bg-[#0f1115] text-amber-400 border-amber-800/50 hover:bg-amber-900/30" data-pricing="freemium">Freemium ({pricingCounts.freemium})</button>
          <button class="pricing-filter text-[11px] font-bold px-4 py-2.5 rounded-lg border transition-colors whitespace-nowrap bg-[#0f1115] text-teal-400 border-teal-800/50 hover:bg-teal-900/30" data-pricing="open-source">Open Source ({pricingCounts['open-source']})</button>
          <button class="pricing-filter text-[11px] font-bold px-4 py-2.5 rounded-lg border transition-colors whitespace-nowrap bg-[#0f1115] text-rose-400 border-rose-800/50 hover:bg-rose-900/30" data-pricing="paid">Paid ({pricingCounts.paid})</button>
        </div>
      </div>

      <div class="mb-20">
        <div class="flex items-center justify-between gap-4 border-b border-gray-800 pb-2 mb-6">
          <h2 class="text-xl font-bold text-white">Agency Playbooks</h2>
          <p class="text-sm text-gray-500">Quick-start combinations for common delivery scenarios.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5">
          {stacksData.map((stack) => (
            <article class="p-6 rounded-xl bg-[#161b22] border border-gray-800 hover:border-blue-800 transition-colors">
              <h3 class="text-lg font-bold text-white mb-2">{stack.name}</h3>
              <p class="text-sm text-gray-400 mb-5">{stack.description}</p>
              <div class="flex flex-wrap gap-2">
                {stack.tools.map((toolName) => (
                  <span class="px-2 py-1 bg-gray-800 rounded font-medium text-xs text-gray-300">{toolName}</span>
                ))}
              </div>
            </article>
          ))}
        </div>
      </div>

      <div id="toolsContainer">
        {categories.map((category, index) => (
          <details class="category-section group mb-6 bg-[#161b22] border border-gray-800 rounded-xl overflow-hidden transition-colors" data-category={category.toLowerCase()} open={index < 3}>
            <summary class="text-xl font-bold text-gray-100 p-5 cursor-pointer flex justify-between items-center hover:bg-[#1f262e] transition-colors outline-none focus:ring-2 focus:ring-blue-500 inset-0">
              <div class="flex items-center gap-3">
                {category}
                <span class="text-xs font-semibold text-gray-400 px-2.5 py-0.5 bg-[#0f1115] border border-gray-800 rounded-full">
                  {normalizedTools.filter((tool) => tool.category === category).length} tools
                </span>
              </div>
              <svg class="w-5 h-5 text-gray-500 transform group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <div class="p-5 border-t border-gray-800 bg-[#0f1115]/50">
              <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5">
                {normalizedTools.filter((tool) => tool.category === category).map((tool) => (
                  <ToolCard tool={tool} />
                ))}
              </div>
            </div>
          </details>
        ))}
      </div>
    </div>

    <aside class="w-full lg:w-[360px] flex-shrink-0 lg:sticky lg:top-8 lg:self-start">
      <div class="rounded-xl border border-gray-800 bg-[#161b22] flex flex-col shadow-2xl overflow-hidden">
        <div class="p-5 border-b border-gray-800 bg-[#0f1115]">
          <div class="flex justify-between items-center mb-3 gap-3">
            <div>
              <h2 class="text-lg font-extrabold text-white flex items-center gap-2">
                <svg class="w-5 h-5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
                My Stack
              </h2>
              <p id="stackSummary" class="mt-2 text-xs text-gray-400">Build a stack and export the chosen tools plus both alternative views.</p>
              <p id="stackStatus" class="mt-1 text-[11px] font-semibold text-gray-500">Ready for discovery</p>
            </div>
            <span id="stackCounter" class="bg-blue-600 text-white text-xs font-bold px-2 py-1 rounded-full">0</span>
          </div>
          <div class="grid grid-cols-3 gap-2 mt-3">
            <button id="btnConvertFree" class="text-[10px] font-bold py-2 px-2 bg-emerald-900/30 text-emerald-400 border border-emerald-800/50 hover:bg-emerald-800 transition rounded shadow-sm">Free Alts</button>
            <button id="btnConvertPro" class="text-[10px] font-bold py-2 px-2 bg-purple-900/30 text-purple-400 border border-purple-800/50 hover:bg-purple-800 transition rounded shadow-sm">Paid Alts</button>
            <button id="btnResetStack" class="text-[10px] font-bold py-2 px-2 bg-gray-800 text-gray-300 border border-gray-700 hover:bg-gray-700 transition rounded shadow-sm hidden" style="display:none;">Reset</button>
          </div>
        </div>

        <div id="stackItems" class="max-h-[420px] lg:max-h-[calc(100vh-28rem)] overflow-y-auto p-4 space-y-3 bg-[#0f1115]">
          <p id="emptyStackMsg" class="text-sm text-gray-500 text-center mt-10 px-4">
            Your stack is empty.<br /><br />
            Click <b class="text-blue-400">“+ Stack”</b> on any tool card to curate a client recommendation.
          </p>
        </div>

        <div class="p-4 border-t border-gray-800 bg-[#161b22]">
          <div class="rounded-lg border border-blue-900/40 bg-blue-950/20 p-3 text-xs text-blue-100 mb-3">
            Exports always include the chosen stack plus both free and paid alternatives in a branded diShine format.
          </div>
          <textarea id="stackNotes" placeholder="Client context or delivery note… (optional)" class="w-full bg-[#0f1115] border border-gray-700 rounded p-3 text-xs text-gray-300 mb-3 h-24 resize-none focus:ring-1 focus:ring-blue-500 outline-none"></textarea>
          <div class="grid grid-cols-2 gap-2 mb-2">
            <button id="previewReportBtn" class="py-2.5 bg-slate-700 hover:bg-slate-600 text-white text-[11px] font-bold rounded-lg shadow-lg transition-colors flex items-center justify-center gap-1">
              Preview
            </button>
            <button id="exportPdfBtn" disabled class="export-btn py-2.5 bg-rose-600 hover:bg-rose-500 text-white text-[11px] font-bold rounded-lg shadow-lg transition-colors flex items-center justify-center gap-1 disabled:opacity-50 disabled:cursor-not-allowed">
              PDF
            </button>
            <button id="exportMdBtn" disabled class="export-btn py-2.5 bg-blue-600 hover:bg-blue-500 text-white text-[11px] font-bold rounded-lg shadow-lg transition-colors flex items-center justify-center gap-1 disabled:opacity-50 disabled:cursor-not-allowed">
              Markdown
            </button>
            <button id="exportTxtBtn" disabled class="export-btn py-2.5 bg-gray-600 hover:bg-gray-500 text-white text-[11px] font-bold rounded-lg shadow-lg transition-colors flex items-center justify-center gap-1 disabled:opacity-50 disabled:cursor-not-allowed">
              TXT
            </button>
          </div>
        </div>
      </div>
    </aside>
  </div>

  <script define:vars={{ toolsData }}>
    window.__DISHINE_TOOLS__ = toolsData;
  </script>

  <script type="module">
    import { initToolkitApp } from '/src/lib/toolkit-app.js';

    initToolkitApp({ tools: window.__DISHINE_TOOLS__ || [] });
  </script>
</Layout>
