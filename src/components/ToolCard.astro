---
const { tool } = Astro.props;
---
<a href={tool.url} target="_blank" rel="noopener noreferrer" class="block p-5 rounded-xl border border-gray-800 bg-[#161b22] hover:bg-gray-800/80 transition-all hover:border-gray-600 group h-full flex flex-col">
  <div class="flex justify-between items-start mb-4 gap-2">
    <div>
      <h3 class="text-base font-semibold text-white group-hover:text-blue-400 flex items-center gap-1.5 leading-tight">
        {tool.name}
        {tool.agencyPick && <span title="diShine Top Pick" class="text-base leading-none translate-y-[-1px]">👑</span>}
      </h3>
      <p class="text-[11px] text-gray-400 mt-1.5 uppercase tracking-wider font-medium opacity-80">{tool.subCategory}</p>
    </div>
    <div class="flex gap-1.5 flex-shrink-0">
      <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-semibold bg-gray-800 text-gray-300 border border-gray-700">
        {tool.type}
      </span>
      {tool.learningCurve === 'Easy' && <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-semibold bg-green-900/30 text-green-400">Easy</span>}
      {tool.learningCurve === 'Medium' && <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-semibold bg-yellow-900/30 text-yellow-500">Medium</span>}
      {tool.learningCurve === 'Steep' && <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-semibold bg-red-900/30 text-red-400">Steep</span>}
    </div>
  </div>
  <p class="text-sm text-gray-400 leading-relaxed flex-grow">{tool.description}</p>
  {tool.alternativeTo && (
    <div class="mt-4 pt-3 border-t border-gray-800/80">
      <p class="text-xs text-gray-500 flex items-center gap-1.5">
        <svg class="h-3 w-3 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7v8a2 2 0 002 2h6M8 7l4 4m-4-4l-4 4" />
        </svg>
        <span class="font-medium text-gray-400">Alt to:</span> {tool.alternativeTo}
      </p>
    </div>
  )}
</a>
