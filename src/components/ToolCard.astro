---
import { getPricingMeta, normalizeTool } from '../lib/toolkit-core.js';

const tool = normalizeTool(Astro.props.tool);
const pricing = getPricingMeta(tool.pricing);
const stackPayload = JSON.stringify({
  id: tool.id,
  name: tool.name,
  url: tool.url,
  desc: tool.desc,
  pricing: tool.pricing,
  cat: tool.cat,
  sub: tool.sub,
  tags: tool.tags,
});
---
<div
  class="tool-card flex flex-col p-4 rounded-lg border border-gray-800 bg-[#161b22] hover:bg-gray-800/80 hover:border-gray-700 transition-all h-full shadow-sm"
  data-name={tool.name.toLowerCase()}
  data-desc={tool.desc.toLowerCase()}
  data-tags={tool.tags.join(' ').toLowerCase()}
  data-category={tool.cat.toLowerCase()}
  data-subcategory={tool.sub.toLowerCase()}
  data-pricing={tool.pricing}
>
  <div class="flex justify-between items-start mb-2 gap-2">
    <a href={tool.url} target="_blank" rel="noopener" class="font-semibold text-white hover:text-blue-400 leading-tight">
      {tool.name} {tool.agencyPick && <span title="diShine Top Pick">👑</span>}
    </a>
    <button class="add-to-stack flex-shrink-0 text-xs bg-blue-900/40 hover:bg-blue-600 text-blue-300 px-2 py-1.5 rounded border border-blue-800/60 transition-colors font-medium shadow-sm" data-tool={stackPayload}>+ Stack</button>
  </div>

  <div class="flex flex-wrap gap-1.5 mb-2">
    {tool.sub && (
      <span class="px-1.5 py-0.5 rounded text-[10px] font-semibold border bg-slate-900/50 text-slate-300 border-slate-700/60">
        {tool.sub}
      </span>
    )}
    {(tool.tags || []).map((tag) => (
      <span class="tag-badge cursor-pointer px-1.5 py-0.5 rounded text-[10px] font-semibold bg-gray-800 hover:bg-gray-700 text-gray-400 border border-gray-700 transition" data-tag={tag.toLowerCase()}>#{tag}</span>
    ))}
    <span class={`px-1.5 py-0.5 rounded text-[10px] font-semibold border ${tool.learningCurve === 'Easy' ? 'bg-green-900/30 text-green-400 border-green-800/50' : tool.learningCurve === 'Steep' ? 'bg-red-900/30 text-red-400 border-red-800/50' : 'bg-yellow-900/30 text-yellow-500 border-yellow-800/50'}`}>
      {tool.learningCurve}
    </span>
    <span class={`px-1.5 py-0.5 rounded text-[10px] font-semibold border ${pricing.badgeClass}`}>
      {pricing.label} {pricing.icon}
    </span>
  </div>

  <p class="text-xs text-gray-400 leading-relaxed flex-grow mb-3">{tool.desc}</p>

  {tool.alternativeTo && (
    <div class="mt-auto pt-3 border-t border-gray-800/80">
      <p class="text-xs text-gray-500 flex items-center gap-1.5">
        <span class="font-medium text-gray-400">Alt to:</span> {tool.alternativeTo}
      </p>
    </div>
  )}
</div>
