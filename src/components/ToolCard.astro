---
const { tool } = Astro.props;
---
<div class="tool-card flex flex-col p-5 rounded-xl border border-gray-800 bg-[#161b22] hover:bg-gray-800/80 transition-all h-full" 
  data-name={(tool.name || '').toLowerCase()} 
  data-desc={(tool.description || '').toLowerCase()}
  data-tags={(tool.tags || []).join(' ').toLowerCase()}
  data-free={tool.isFree ? "true" : "false"}
  data-os={tool.isOpenSource ? "true" : "false"}>
  
  <div class="flex justify-between items-start mb-3 gap-2">
    <a href={tool.url} target="_blank" rel="noopener flex-grow" class="font-semibold text-white hover:text-blue-400 leading-tight">
      {tool.name} {tool.agencyPick && <span title="diShine Top Pick">👑</span>}
    </a>
    <button class="add-to-stack flex-shrink-0 text-xs bg-blue-900/40 hover:bg-blue-600 text-blue-300 px-2 py-1.5 rounded border border-blue-800/60 transition-colors font-medium shadow-sm" data-tool={JSON.stringify({name: tool.name, url: tool.url, desc: tool.description})}>+ Stack</button>
  </div>
  
  <div class="flex flex-wrap gap-1.5 mb-3">
    {(tool.tags || []).map((tag: string) => (
      <span class="tag-badge cursor-pointer px-1.5 py-0.5 rounded text-[10px] font-semibold bg-gray-800 hover:bg-gray-700 text-gray-400 border border-gray-700 transition" data-tag={tag.toLowerCase()}>#{tag}</span>
    ))}
    <span class={`px-1.5 py-0.5 rounded text-[10px] font-semibold border ${tool.learningCurve === 'Easy' ? 'bg-green-900/30 text-green-400 border-green-800/50' : tool.learningCurve === 'Steep' ? 'bg-red-900/30 text-red-400 border-red-800/50' : 'bg-yellow-900/30 text-yellow-500 border-yellow-800/50'}`}>{tool.learningCurve}</span>
    <span class={`px-1.5 py-0.5 rounded text-[10px] font-semibold border ${tool.type.includes('[$]') && !tool.type.includes('[F]') ? 'bg-rose-900/30 text-rose-400 border-rose-800/50' : tool.type.includes('[$]') && tool.type.includes('[F]') ? 'bg-amber-900/30 text-amber-500 border-amber-800/50' : tool.type.includes('[OS]') ? 'bg-emerald-900/30 text-emerald-400 border-emerald-800/50' : 'bg-emerald-900/30 text-emerald-400 border-emerald-800/50'}`}>{tool.type.includes('[$]') && !tool.type.includes('[F]') ? 'Paid 💎' : tool.type.includes('[$]') && tool.type.includes('[F]') ? 'Freemium ⚖️' : tool.type.includes('[OS]') ? 'Open Source 🌐' : 'Free 🍏'}</span>
  </div>
  <p class="text-sm text-gray-400 leading-relaxed flex-grow mb-4">{tool.description}</p>
  
  {tool.alternativeTo && (
    <div class="mt-auto pt-3 border-t border-gray-800/80">
      <p class="text-xs text-gray-500 flex items-center gap-1.5">
        <span class="font-medium text-gray-400">Alt to:</span> {tool.alternativeTo}
      </p>
    </div>
  )}
</div>
